<Window x:Class="GameAssetExplorer.App.Views.TexturePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Texture Preview"
        Width="1000" Height="720"
        MinWidth="500" MinHeight="380"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="40"/>
            <!-- Image canvas -->
            <RowDefinition Height="*"/>
            <!-- Status -->
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Asset info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblName"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblMeta"
                               FontSize="11"
                               Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Save button -->
                <Button Grid.Column="1"
                        Content="💾  Save PNG…"
                        Style="{StaticResource PrimaryBtn}"
                        Padding="12,5"
                        VerticalAlignment="Center"
                        Click="OnSavePng"/>
            </Grid>
        </Border>

        <!-- ── Image Canvas ────────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              x:Name="ImageHost"
              Background="#0A0A0B"
              ClipToBounds="True"
              MouseWheel="OnMouseWheel"
              MouseLeftButtonDown="OnMouseDown"
              MouseLeftButtonUp="OnMouseUp"
              MouseMove="OnMouseMove"
              SizeChanged="OnHostSizeChanged">
            <Image x:Name="Img"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top">
                <Image.RenderTransform>
                    <MatrixTransform x:Name="Xform"/>
                </Image.RenderTransform>
            </Image>

            <!-- Empty state -->
            <TextBlock x:Name="LblEmpty"
                       Text="Texture could not be decoded."
                       Foreground="{StaticResource TextMuted}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- ── Status Strip ────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="LblStatus"
                           FontSize="11"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center"
                           Text="Scroll to zoom  ·  Drag to pan  ·  Double-click to reset"/>
                <TextBlock Grid.Column="1"
                           x:Name="LblZoom"
                           FontSize="11"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center"
                           Text="100%"/>
            </Grid>
        </Border>
    </Grid>
</Window>
