<Window x:Class="GameAssetExplorer.App.Views.AddGameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Game"
        Width="520" Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Form fields -->
            <RowDefinition Height="*"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Dialog Title ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="DialogTitle"
                       Text="Add Game"
                       FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Configure a game to add it to your library."
                       FontSize="12"
                       Foreground="{StaticResource TextSub}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Form ───────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel" Margin="0,0,0,8">

                <!-- Display Name -->
                <TextBlock Text="Display Name" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDisplayName" Margin="0,0,0,14"
                         ToolTip="e.g. Star Wars Jedi: Survivor"/>

                <!-- Game Directory -->
                <TextBlock Text="Game Directory" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtGameDir" Grid.Column="0" Margin="0,0,6,0"
                             ToolTip="Root install directory of the game"/>
                    <Button Grid.Column="1" Content="Browse…" Width="80"
                            Click="OnBrowseDirectory"/>
                </Grid>

                <!-- Auto-detect hint -->
                <Border x:Name="DetectHint"
                        Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="DetectHintText"
                                   FontSize="12" Foreground="{StaticResource TextSub}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnUseDetected"
                                Content="Use"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="10,0,0,0"
                                Click="OnUseDetectedEngine"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Engine -->
                <TextBlock Text="Engine" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbEngine"
                          DisplayMemberPath="EngineName"
                          Margin="0,0,0,14"
                          SelectionChanged="OnEngineSelectionChanged"/>

                <!-- Game preset (UE only) — FModel-style: pick the game, version + serialization quirks follow -->
                <StackPanel x:Name="PresetSection" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,4">
                        Game preset
                        <Run Foreground="{StaticResource TextMuted}" FontSize="11"> (recommended — picks the right CUE4Parse game ID for known UE titles)</Run>
                    </TextBlock>
                    <ComboBox x:Name="CmbPreset"
                              Margin="0,0,0,4"
                              SelectionChanged="OnPresetSelectionChanged"/>
                    <TextBlock x:Name="LblPresetHint"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Engine Version -->
                <TextBlock Text="Engine Version" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbVersion" Margin="0,0,0,14"/>

                <!-- AES Key (shown only for UE games) -->
                <StackPanel x:Name="AesSection" Visibility="Collapsed" Margin="0,0,0,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,4">
                        AES Decryption Key
                        <Run Foreground="{StaticResource TextMuted}" FontSize="11"> (leave blank to try without one first)</Run>
                    </TextBlock>
                    <TextBox x:Name="TxtAesKey"
                             FontFamily="Consolas" FontSize="12"
                             Margin="0,0,0,4"
                             ToolTip="Format: 0x followed by 64 hex characters. Leave blank — the tool will tell you if it's needed."/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,14">
                        Many games work without a key. If files won't open, check aeskeys.com for your game's key.
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Buttons ────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="Save" Width="90" Style="{StaticResource PrimaryBtn}" Click="OnSave"/>
        </StackPanel>
    </Grid>

</Window>
