<Window x:Class="GameAssetExplorer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GameAssetExplorer.App.ViewModels"
        xmlns:views="clr-namespace:GameAssetExplorer.App.Views"
        Title="{Binding WindowTitle}"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DataTemplates in App.xaml handle routing HomeViewModel→HomeView, etc. -->
        <ContentControl Grid.Row="0" Content="{Binding CurrentView}" Focusable="False"/>

        <!-- Always-available log drawer -->
        <views:LogPanel Grid.Row="1"/>
    </Grid>

</Window>
