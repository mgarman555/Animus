<Window x:Class="GameAssetExplorer.App.Views.SkeletalMeshViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skeletal Mesh Viewer"
        Width="1080" Height="680"
        MinWidth="600" MinHeight="400"
        Background="#1A1A1B"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#3F3F46"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="SubtitleText"
                               FontSize="11" Foreground="#555555"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="LOD"
                               FontSize="11" Foreground="#777777"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <ComboBox x:Name="LodCombo"
                              Width="60"
                              FontSize="11"
                              Background="#2D2D30"
                              Foreground="#CCCCCC"
                              BorderBrush="#3F3F46"
                              VerticalAlignment="Center"
                              SelectionChanged="OnLodChanged"
                              Visibility="Collapsed"/>
                    <Button x:Name="BtnReset"
                            Content="Reset Camera"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="10,4"
                            FontSize="11"
                            Margin="8,0,0,0"
                            Background="#2D2D30"
                            Foreground="#AAAAAA"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="OnResetCamera"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content row: viewport + display panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240" x:Name="DisplayPanelColumn"/>
            </Grid.ColumnDefinitions>

            <!-- Viewport -->
            <Grid Grid.Column="0" x:Name="ViewportContainer" Background="#141415">
                <Viewport3D x:Name="Viewport3D" Visibility="Collapsed">
                    <Viewport3D.Camera>
                        <PerspectiveCamera x:Name="Camera"
                                           Position="0,1,4"
                                           LookDirection="0,-0.2,-1"
                                           UpDirection="0,1,0"
                                           FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <Model3DGroup>
                                <AmbientLight Color="#303030"/>
                                <DirectionalLight Color="#E8E0D8" Direction="-1,-1.5,-1"/>
                                <DirectionalLight Color="#6060A0" Direction="1,0.5,1"/>
                                <DirectionalLight Color="#302820" Direction="0,1,0"/>
                            </Model3DGroup>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                    <ModelVisual3D x:Name="MeshVisual"/>
                    <ModelVisual3D x:Name="ArmatureVisual"/>
                </Viewport3D>

                <!-- Placeholder -->
                <StackPanel x:Name="PlaceholderPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="⬡"
                               FontSize="52" Foreground="#2A2A2C"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PlaceholderTitle"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#555555"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,6"/>
                    <TextBlock x:Name="PlaceholderSub"
                               FontSize="11" Foreground="#3C3C3C"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>
                    <Button Content="Browse for .obj …"
                            HorizontalAlignment="Center"
                            Padding="14,6"
                            FontSize="12"
                            Background="#2D2D30"
                            Foreground="#AAAAAA"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="OnBrowseObj"/>
                </StackPanel>
            </Grid>

            <!-- ── Display panel (Blender-like outliner) ──────────────────── -->
            <Border Grid.Column="1"
                    x:Name="DisplayPanel"
                    Background="#1E1E1F"
                    BorderBrush="#3F3F46"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#252526"
                            BorderBrush="#3F3F46"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="display"
                                   FontSize="10"
                                   Foreground="#777777"
                                   VerticalAlignment="Center"
                                   Margin="12,0"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,10">

                            <!-- Display category toggles -->
                            <CheckBox x:Name="ChkTexture"
                                      Content="Texture"
                                      FontSize="12"
                                      Foreground="#CCCCCC"
                                      IsChecked="True"
                                      Margin="0,2"
                                      Click="OnToggleTexture"/>

                            <CheckBox x:Name="ChkArmature"
                                      Content="Armature / Bones"
                                      FontSize="12"
                                      Foreground="#CCCCCC"
                                      IsChecked="False"
                                      IsEnabled="False"
                                      Margin="0,2"
                                      Click="OnToggleArmature"/>

                            <CheckBox x:Name="ChkWireframe"
                                      Content="Wireframe"
                                      FontSize="12"
                                      Foreground="#CCCCCC"
                                      IsChecked="False"
                                      Margin="0,2"
                                      Click="OnToggleWireframe"/>

                            <!-- ── Texture debug (Session 3) ─────────────── -->
                            <TextBlock Text="texture debug"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="0,10,0,4"/>

                            <CheckBox x:Name="ChkSkipUntile"
                                      Content="Skip GOB untile"
                                      FontSize="11"
                                      Foreground="#CCCCCC"
                                      IsChecked="True"
                                      Margin="0,2"
                                      ToolTip="TLOU2 PC textures are already linear — keep this ON. Untoggle to test the GOB swizzle path."
                                      Click="OnToggleSkipUntile"/>

                            <CheckBox x:Name="ChkSwapRB"
                                      Content="Swap R / B channels"
                                      FontSize="11"
                                      Foreground="#CCCCCC"
                                      IsChecked="True"
                                      Margin="0,2"
                                      ToolTip="BC1/BC7 decodes to RGB; WPF needs BGRA. Disable if the source is already BGR-ordered."
                                      Click="OnToggleSwapRB"/>

                            <CheckBox x:Name="ChkFlipV"
                                      Content="Flip vertically"
                                      FontSize="11"
                                      Foreground="#CCCCCC"
                                      IsChecked="False"
                                      Margin="0,2"
                                      ToolTip="DX-style top-down vs GL-style bottom-up storage."
                                      Click="OnToggleFlipV"/>

                            <CheckBox x:Name="ChkHonorAlpha"
                                      Content="Honor BC1 punch-through alpha"
                                      FontSize="11"
                                      Foreground="#CCCCCC"
                                      IsChecked="False"
                                      Margin="0,2"
                                      ToolTip="BC1 with color0≤color1 encodes 1-bit alpha. For diffuse color textures this is almost never meaningful — leaving this OFF forces alpha=255 so the mesh's back material doesn't bleed through."
                                      Click="OnToggleHonorAlpha"/>

                            <ComboBox x:Name="CmbForceFormat"
                                      FontSize="11"
                                      Margin="0,4,0,0"
                                      Background="#2D2D30"
                                      Foreground="#CCCCCC"
                                      BorderBrush="#3F3F46"
                                      SelectionChanged="OnForceFormatChanged"
                                      ToolTip="Force a specific BCn format for decoding (test hypothesis: format ID is wrong)">
                                <ComboBoxItem Content="Format: (auto)" IsSelected="True"/>
                                <ComboBoxItem Content="Format: BC1"/>
                                <ComboBoxItem Content="Format: BC3"/>
                                <ComboBoxItem Content="Format: BC4"/>
                                <ComboBoxItem Content="Format: BC5"/>
                                <ComboBoxItem Content="Format: BC7"/>
                            </ComboBox>

                            <Button Content="🔍 Auto-detect settings"
                                    FontSize="11"
                                    Padding="6,4"
                                    Margin="0,6,0,0"
                                    Background="#0E639C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="Probe every combination of skip/swap/flip/format and pick the one with the lowest Total Variation (most coherent image). Runs automatically on every asset load."
                                    Click="OnAutoDetectTexture"/>

                            <Button Content="📁 Dump texture bytes"
                                    FontSize="11"
                                    Padding="6,4"
                                    Margin="0,6,0,0"
                                    Background="#2D2D30"
                                    Foreground="#CCCCCC"
                                    BorderBrush="#3F3F46"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    Click="OnDumpTextureBytes"/>

                            <Separator Background="#3F3F46" Margin="0,10,0,8"/>

                            <!-- Submeshes header -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Submeshes"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#AAAAAA"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="all"
                                            FontSize="10"
                                            Padding="6,1"
                                            Background="Transparent"
                                            Foreground="#888888"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="OnSubmeshShowAll"/>
                                    <Button Content="none"
                                            FontSize="10"
                                            Padding="6,1"
                                            Background="Transparent"
                                            Foreground="#888888"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="OnSubmeshHideAll"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl x:Name="SubmeshList"/>

                            <TextBlock x:Name="LblNoSubmeshes"
                                       Text="(no submesh data)"
                                       FontSize="10"
                                       Foreground="#555555"
                                       FontStyle="Italic"
                                       Margin="0,4,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
