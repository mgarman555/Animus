<UserControl x:Class="GameAssetExplorer.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GameAssetExplorer.App.ViewModels"
             xmlns:conv="clr-namespace:GameAssetExplorer.App.Views.Converters"
             Background="{StaticResource Bg}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="52"/>
            <!-- Library content -->
            <RowDefinition Height="*"/>
            <!-- Status strip -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Library"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Games.Count, StringFormat=' ({0} games)'}"
                               FontSize="13"
                               Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Toolbar buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📄  Logs"
                            Style="{StaticResource GhostBtn}"
                            Padding="10,5"
                            Margin="0,0,8,0"
                            ToolTip="Open the log folder for sharing diagnostics"
                            Click="OnOpenLogsClick"/>
                    <Button Content="＋  Load Game"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding AddGameCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Game Library Grid ─────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,80,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Games.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No games configured yet"
                               FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource TextSub}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Click  ＋ Load Game  to get started."
                               FontSize="13"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Game card grid -->
                <ItemsControl x:Name="GameCardsControl"
                              ItemsSource="{Binding Games}"
                              Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GameLibraryEntry}">
                            <!-- Game Card -->
                            <Border x:Name="Card"
                                    Width="180" Height="260"
                                    Margin="8"
                                    CornerRadius="6"
                                    Background="{StaticResource Surface}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Tag="{Binding}">
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="CardBorder" Color="#3F3F46"/>
                                </Border.BorderBrush>

                                <!-- Right-click context menu -->
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Edit Game Info"
                                                  Click="OnCardEditMenuClick"/>
                                        <Separator/>
                                        <MenuItem Header="Remove from Library"
                                                  Click="OnCardDeleteMenuClick"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <!-- Single click selects, double-click opens -->
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectGameCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.OpenGameCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="195"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- ⋮ menu button (top-right corner of card) -->
                                    <Button Grid.Row="0"
                                            Content="⋮"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Width="28" Height="28"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,4,4,0"
                                            Panel.ZIndex="2"
                                            Foreground="White"
                                            Background="#80000000"
                                            BorderThickness="0"
                                            Padding="0,-4,0,0"
                                            Cursor="Hand"
                                            ToolTip="Edit / Remove"
                                            Click="OnCardMenuButtonClick"/>

                                    <!-- Cover area -->
                                    <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True">
                                        <Grid>
                                            <!-- Gradient placeholder -->
                                            <Border x:Name="GradientPlaceholder">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverImagePath,
                                                                Converter={StaticResource NotNullConverter}}"
                                                                Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#0e3a6e" Offset="0"/>
                                                        <GradientStop Color="#061e40" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding DisplayName[0]}"
                                                           FontSize="72" FontWeight="Bold"
                                                           Foreground="White" Opacity="0.08"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Cover art image -->
                                            <Image Source="{Binding CoverImagePath}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverImagePath,
                                                                Converter={StaticResource NotNullConverter}}"
                                                                Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>

                                    <!-- Info area -->
                                    <StackPanel Grid.Row="1" Margin="10,8,10,10" VerticalAlignment="Center">
                                        <!-- Game name -->
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Engine / version subtitle -->
                                        <TextBlock Text="{Binding SubtitleDisplay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextSub}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card selected trigger -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- ── Status Strip ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center"/>

                <!-- Loading indicator -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Loading…"
                               FontSize="11"
                               Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</UserControl>
