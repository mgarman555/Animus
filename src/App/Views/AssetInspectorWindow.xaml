<Window x:Class="GameAssetExplorer.App.Views.AssetInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inspector"
        Width="720" Height="600"
        MinWidth="400" MinHeight="320"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LblIcon"
                           Grid.Column="0"
                           FontSize="28"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSub}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="LblName"
                               FontSize="14" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="LblPath"
                               FontSize="11"
                               Foreground="{StaticResource TextSub}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Properties scroll -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PropsPanel" Margin="16,12"/>
        </ScrollViewer>
    </Grid>
</Window>
