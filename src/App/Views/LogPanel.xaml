<UserControl x:Class="GameAssetExplorer.App.Views.LogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition x:Name="BodyRow" Height="0"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar (always visible) ─────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0"
                Cursor="Hand"
                MouseLeftButtonDown="OnHeaderClick">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ChevronText"
                           Grid.Column="0"
                           Text="▸"
                           FontSize="11"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <TextBlock Grid.Column="1"
                           Text="📄  Logs"
                           FontSize="11"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="LblTail"
                           Grid.Column="2"
                           FontSize="10"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Copy"
                            Style="{StaticResource GhostBtn}"
                            FontSize="10"
                            Padding="6,2"
                            Margin="0,0,4,0"
                            Click="OnCopy"
                            PreviewMouseLeftButtonDown="OnButtonStopBubble"/>
                    <Button Content="Save…"
                            Style="{StaticResource GhostBtn}"
                            FontSize="10"
                            Padding="6,2"
                            Margin="0,0,4,0"
                            Click="OnSave"
                            PreviewMouseLeftButtonDown="OnButtonStopBubble"/>
                    <Button Content="Clear"
                            Style="{StaticResource GhostBtn}"
                            FontSize="10"
                            Padding="6,2"
                            Margin="0,0,4,0"
                            Click="OnClear"
                            PreviewMouseLeftButtonDown="OnButtonStopBubble"/>
                    <Button Content="Open File"
                            Style="{StaticResource GhostBtn}"
                            FontSize="10"
                            Padding="6,2"
                            Click="OnOpenFile"
                            PreviewMouseLeftButtonDown="OnButtonStopBubble"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Body (only visible when expanded) ───────────────────────── -->
        <Border Grid.Row="1"
                Background="#0A0A0B"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0">
            <RichTextBox x:Name="LogRtb"
                         IsReadOnly="True"
                         IsDocumentEnabled="True"
                         Background="#0A0A0B"
                         Foreground="#CCCCCC"
                         BorderThickness="0"
                         Padding="6,4"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="11"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         IsUndoEnabled="False"
                         AcceptsReturn="False"
                         AcceptsTab="False">
                <RichTextBox.Document>
                    <FlowDocument PagePadding="0" PageWidth="2000"/>
                </RichTextBox.Document>
            </RichTextBox>
        </Border>
    </Grid>
</UserControl>
